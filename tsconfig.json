{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2018",
    "module": "commonjs",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "strictBindCallApply": false,
    "strict": true,
    "noImplicitAny": true,
    "alwaysStrict": true,
    "sourceMap": true,
    "noEmit": false,
    "removeComments": true,
    "importHelpers": true,
    "strictNullChecks": true,
    "lib": ["es2018"],
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@types"],
    "types": [
      "node",
      "koa",
      "lodash"
    ],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "./src/*.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "public"
  ]
}